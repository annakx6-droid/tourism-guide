<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark text-center">
                    <h4 class="m-0">ແກ້ໄຂຂໍ້ມູນສະຖານທີ່</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/update-place/<%= place.id %>" method="POST" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">ຊື່ສະຖານທີ່</label>
                            <input type="text" name="name" class="form-control" value="<%= place.name %>" required>
                        </div>

                                                <div class="mb-3">
                            <label class="form-label fw-bold">ແຂວງ</label>
                            <select name="province" class="form-select" required> 
                                <option value="ນະຄອນຫຼວງ" <%= place.province == 'ນະຄອນຫຼວງ' ? 'selected' : '' %>>ນະຄອນຫຼວງ</option>
                                <option value="ຜົ້ງສາລີ" <%= place.province == 'ຜົ້ງສາລີ' ? 'selected' : '' %>>ຜົ້ງສາລີ</option>
                                <option value="ຫຼວງນ້ຳທາ" <%= place.province == 'ຫຼວງນ້ຳທາ' ? 'selected' : '' %>>ຫຼວງນ້ຳທາ</option>
                                <option value="ອຸດົມໄຊ" <%= place.province == 'ອຸດົມໄຊ' ? 'selected' : '' %>>ອຸດົມໄຊ</option>
                                <option value="ບໍ່ແກ້ວ" <%= place.province == 'ບໍ່ແກ້ວ' ? 'selected' : '' %>>ບໍ່ແກ້ວ</option>
                                <option value="ຫຼວງພະບາງ" <%= place.province == 'ຫຼວງພະບາງ' ? 'selected' : '' %>>ຫຼວງພະບາງ</option>
                                <option value="ຫົວພັນ" <%= place.province == 'ຫົວພັນ' ? 'selected' : '' %>>ຫົວພັນ</option>
                                <option value="ໄຊຍະບູລີ" <%= place.province == 'ໄຊຍະບູລີ' ? 'selected' : '' %>>ໄຊຍະບູລີ</option>
                                <option value="ຊຽງຂວາງ" <%= place.province == 'ຊຽງຂວາງ' ? 'selected' : '' %>>ຊຽງຂວາງ</option>
                                <option value="ໄຊສົມບູນ" <%= place.province == 'ໄຊສົມບູນ' ? 'selected' : '' %>>ໄຊສົມບູນ</option>
                                <option value="ວຽງຈັນ" <%= place.province == 'ວຽງຈັນ' ? 'selected' : '' %>>ແຂວງວຽງຈັນ</option>
                                <option value="ບໍລິຄຳໄຊ" <%= place.province == 'ບໍລິຄຳໄຊ' ? 'selected' : '' %>>ບໍລິຄຳໄຊ</option>
                                <option value="ຄຳມ່ວນ" <%= place.province == 'ຄຳມ່ວນ' ? 'selected' : '' %>>ຄຳມ່ວນ</option>
                                <option value="ສະຫວັນນະເຂດ" <%= place.province == 'ສະຫວັນນະເຂດ' ? 'selected' : '' %>>ສະຫວັນນະເຂດ</option>
                                <option value="ສາລະວັນ" <%= place.province == 'ສາລະວັນ' ? 'selected' : '' %>>ສາລະວັນ</option>
                                <option value="ເຊກອງ" <%= place.province == 'ເຊກອງ' ? 'selected' : '' %>>ເຊກອງ</option>
                                <option value="ຈຳປາສັກ" <%= place.province == 'ຈຳປາສັກ' ? 'selected' : '' %>>ຈຳປາສັກ</option>
                                <option value="ອັດຕະປື" <%= place.province == 'ອັດຕະປື' ? 'selected' : '' %>>ອັດຕະປື</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">ໝວດໝູ່</label>
                            <select name="category" class="form-select" required>
                                <option value="ວັດທະນາທຳ" <%= (typeof place !== 'undefined' && place.category == 'ວັດທະນາທຳ') ? 'selected' : '' %>>ວັດທະນາທຳ</option>
                                <option value="ທຳມະຊາດ" <%= (typeof place !== 'undefined' && place.category == 'ທຳມະຊາດ') ? 'selected' : '' %>>ແຫຼ່ງທ່ອງທ່ຽວທຳມະຊາດ</option>
                            </select>
                        </div>

                      <div class="mb-3">
                            <label class="form-label fw-bold d-block">ຮູບພາບປະຈຸບັນ</label>
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <% if (place.image) { %>
                                    <img src="<%= place.image %>" class="img-thumbnail" style="height: 80px; width: 80px; object-fit: cover;">
                                <% } %>
                            </div>
                            
                            <label class="form-label d-block small text-muted">ເລືອກຮູບໃໝ່ (ເລືອກໄດ້ຫຼາຍຮູບ, ຖ້າເລືອກໃໝ່ຮູບເກົ່າຈະຖືກປ່ຽນ)</label>
                            <input type="file" name="images" class="form-control" accept="image/*" multiple>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">ລາຍລະອຽດ</label>
                            <textarea name="description" class="form-control" rows="4" required><%= place.description %></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Google Maps Embed URL</label>
                            <input type="text" name="map_url" class="form-control" placeholder="Link ຈາກ Google Maps (Embed)" value="<%= place.map_url %>">
                            <small class="text-muted d-block mt-1">ກັອບເອົາສະເພາະ Link ໃນ src="..." ຂອງ Iframe</small>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning py-2 fw-bold">
                                <i class="bi bi-check-circle"></i> ບັນທຶກການແກ້ໄຂ
                            </button>
                            <a href="/places" class="btn btn-light border">ຍົກເລີກ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>