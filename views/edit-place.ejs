<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-warning text-dark text-center">
                    <h4 class="m-0">ແກ້ໄຂຂໍ້ມູນສະຖານທີ່</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/update-place/<%= place.id %>" method="POST" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">ຊື່ສະຖານທີ່</label>
                            <input type="text" name="name" class="form-control" value="<%= place.name %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">ແຂວງ</label>
                            <select name="province" class="form-select" required>  
                            <option value="ນະຄອນຫຼວງ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ນະຄອນຫຼວງ' ? 'selected' : '' %>>ນະຄອນຫຼວງ</option>
                            <option value="ຜົ້ງສາລີ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຜົ້ງສາລີ' ? 'selected' : '' %>>ຜົ້ງສາລີ</option>
                            <option value="ຫຼວງນ້ຳທາ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຫຼວງນ້ຳທາ' ? 'selected' : '' %>>ຫຼວງນ້ຳທາ</option>
                            <option value="ອຸດົມໄຊ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ອຸດົມໄຊ' ? 'selected' : '' %>>ອຸດົມໄຊ</option>
                            <option value="ບໍ່ແກ້ວ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ບໍ່ແກ້ວ' ? 'selected' : '' %>>ບໍ່ແກ້ວ</option>
                            <option value="ຫຼວງພະບາງ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຫຼວງພະບາງ' ? 'selected' : '' %>>ຫຼວງພະບາງ</option>
                            <option value="ຫົວພັນ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຫົວພັນ' ? 'selected' : '' %>>ຫົວພັນ</option>
                            <option value="ໄຊຍະບູລີ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ໄຊຍະບູລີ' ? 'selected' : '' %>>ໄຊຍະບູລີ</option>
                            <option value="ຊຽງຂວາງ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຊຽງຂວາງ' ? 'selected' : '' %>>ຊຽງຂວາງ</option>
                            <option value="ໄຊສົມບູນ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ໄຊສົມບູນ' ? 'selected' : '' %>>ໄຊສົມບູນ</option>
                            <option value="ວຽງຈັນ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ວຽງຈັນ' ? 'selected' : '' %>>ແຂວງວຽງຈັນ</option>
                            <option value="ບໍລິຄຳໄຊ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ບໍລິຄຳໄຊ' ? 'selected' : '' %>>ບໍລິຄຳໄຊ</option>
                            <option value="ຄຳມ່ວນ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຄຳມ່ວນ' ? 'selected' : '' %>>ຄຳມ່ວນ</option>
                            <option value="ສະຫວັນນະເຂດ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ສະຫວັນນະເຂດ' ? 'selected' : '' %>>ສະຫວັນນະເຂດ</option>
                            <option value="ສາລະວັນ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ສາລະວັນ' ? 'selected' : '' %>>ສາລະວັນ</option>
                            <option value="ເຊກອງ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ເຊກອງ' ? 'selected' : '' %>>ເຊກອງ</option>
                            <option value="ຈຳປາສັກ" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ຈຳປາສັກ' ? 'selected' : '' %>>ຈຳປາສັກ</option>
                            <option value="ອັດຕະປື" <%= typeof selectedProvince !== 'undefined' && selectedProvince == 'ອັດຕະປື' ? 'selected' : '' %>>ອັດຕະປື</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold d-block">ຮູບພາບປະຈຸບັນ</label>
                            <img src="<%= place.image %>" class="img-thumbnail mb-2" style="max-height: 150px;">
                            
                            <label class="form-label d-block small text-muted">ປ່ຽນຮູບໃໝ່ (ປາໄວ້ຫວ່າງໄດ້ ຖ້າບໍ່ຢາກປ່ຽນ)</label>
                            <input type="file" name="image" class="form-control" accept="image/*">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">ລາຍລະອຽດ</label>
                            <textarea name="description" class="form-control" rows="4" required><%= place.description %></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Google Maps Embed URL</label>
                            <input type="text" name="map_url" class="form-control" placeholder="Link ຈາກ Google Maps (Embed)" value="<%= place.map_url %>">
                            <small class="text-muted d-block mt-1">ກັອບເອົາສະເພາະ Link ໃນ src="..." ຂອງ Iframe</small>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-warning py-2 fw-bold">
                                <i class="bi bi-check-circle"></i> ບັນທຶກການແກ້ໄຂ
                            </button>
                            <a href="/places" class="btn btn-light border">ຍົກເລີກ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>